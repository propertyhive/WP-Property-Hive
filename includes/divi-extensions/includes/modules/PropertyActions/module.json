{
  "name": "propertyhive/property-actions",
  "moduleClassName": "et_pb_property_actions_widget",
  "moduleOrderClassName": "et_pb_property_actions_widget",
  "d4Shortcode": "et_pb_property_actions_widget",
  "title": "Property Actions",
  "titles": "Property Actions",
  "moduleIcon": "divi/module",
  "category": "module",
  "childrenName": [],
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "styleProps": {
        "background": {
          "selector": "{{selector}}"
        },
        "spacing": {
          "selector": "{{selector}}",
          "important": true
        },
        "sizing": {
          "propertySelectors": {
            "desktop": {
              "value": {
                "margin-left": "{{selector}}.et_pb_module",
                "margin-right": "{{selector}}.et_pb_module"
              }
            }
          },
          "important": {
            "desktop": {
              "value": {
                "margin-left": true,
                "margin-right": true
              }
            }
          }
        },
        "border": {
          "selector": "{{selector}}"
        },
        "filter": {
          "selector": "{{selector}}"
        },
        "position": {
          "selector": "{{selector}}",
          "important": true
        }
      },
      "settings": {
        "meta": {
          "meta": {}
        },
        "advanced": {
          "html": {},
          "link": {},
          "loop": {}
        },
        "decoration": {
          "animation": {},
          "attributes": {},
          "background": {},
          "border": {},
          "boxShadow": {},
          "conditions": {},
          "disabledOn": {},
          "filters": {},
          "interactions": {},
          "overflow": {},
          "order": {},
          "position": {},
          "scroll": {},
          "sizing": {},
          "spacing": {},
          "sticky": {},
          "transform": {},
          "transition": {},
          "zIndex": {}
        }
      }
    },
    "propertyActions": {
      "type": "object",
      "selector": "{{selector}} .property_actions",
      "settings": {
        "advanced": {
          "display": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "contentDisplay",
              "attrName": "propertyActions.advanced.display",
              "label": "Display As",
              "description": "Choose how the property actions are displayed.",
              "category": "basic_option",
              "priority": 10,
              "render": true,
              "features": {
                "hover": false,
                "sticky": false,
                "responsive": false,
                "preset": "content"
              },
              "component": {
                "type": "field",
                "name": "divi/select",
                "props": {
                  "options": {
                    "list": {
                      "label": "List"
                    },
                    "buttons": {
                      "label": "Buttons"
                    }
                  }
                }
              }
            }
          }
        },
        "decoration": {
          "buttonBackgroundColor": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designButtons",
              "attrName": "propertyActions.decoration.buttonBackgroundColor",
              "label": "Button Background Color",
              "description": "Choose the background color used when actions are shown as buttons.",
              "category": "configuration",
              "priority": 10,
              "render": true,
              "features": {
                "sticky": false,
                "preset": "content"
              },
              "component": {
                "type": "field",
                "name": "divi/color-picker"
              }
            }
          },
          "buttonTextColor": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designButtons",
              "attrName": "propertyActions.decoration.buttonTextColor",
              "label": "Button Text Color",
              "description": "Choose the text color used when actions are shown as buttons.",
              "category": "configuration",
              "priority": 20,
              "render": true,
              "features": {
                "sticky": false,
                "preset": "content"
              },
              "component": {
                "type": "field",
                "name": "divi/color-picker"
              }
            }
          },
          "buttonPadding": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designButtons",
              "attrName": "propertyActions.decoration.buttonPadding",
              "label": "Button Padding",
              "description": "Enter the button padding value, for example 10px 15px.",
              "category": "configuration",
              "priority": 30,
              "render": true,
              "features": {
                "hover": false,
                "sticky": false,
                "responsive": false,
                "preset": "content"
              },
              "component": {
                "type": "field",
                "name": "divi/text"
              }
            }
          },
          "buttonMargin": {
            "groupType": "group-item",
            "item": {
              "groupSlug": "designButtons",
              "attrName": "propertyActions.decoration.buttonMargin",
              "label": "Button Margin",
              "description": "Enter the button margin value, for example 0 5px 0 0.",
              "category": "configuration",
              "priority": 40,
              "render": true,
              "features": {
                "hover": false,
                "sticky": false,
                "responsive": false,
                "preset": "content"
              },
              "component": {
                "type": "field",
                "name": "divi/text"
              }
            }
          }
        }
      }
    }
  },
  "customCssFields": {
    "main": {
      "label": "Main Element",
      "subName": "main",
      "selectorSuffix": ""
    },
    "actions": {
      "label": "Actions",
      "subName": "actions",
      "selectorSuffix": " .property_actions"
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentDisplay": {
        "panel": "content",
        "priority": 10,
        "groupName": "display",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Display",
            "preset": "content"
          }
        }
      },
      "designButtons": {
        "panel": "design",
        "priority": 10,
        "groupName": "buttons",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Buttons",
            "preset": "content"
          }
        }
      }
    }
  }
}
