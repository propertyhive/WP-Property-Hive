{
  "name": "propertyhive/property-gallery",
  "title": "Property Gallery",
  "titles": "Property Gallery",
  "category": "module",
  "moduleClassName": "propertyhive_divi5_property_gallery",
  "moduleOrderClassName": "propertyhive_divi5_property_gallery",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Property Gallery"
            }
          }
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "decoration": {
          "layout": {},
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "disabledOn": {},
          "position": {},
          "zIndex": {}
        }
      }
    },
    "contentText": {
      "type": "object",
      "selector": "{{selector}} .propertyhive-divi5-property-gallery",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true,
                  "font-size": true,
                  "font-family": true,
                  "font-weight": true,
                  "line-height": true,
                  "letter-spacing": true,
                  "text-shadow": true
                }
              }
            }
          }
        }
      }
    },
    "galleryLayout": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "grid"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyGallery",
            "priority": 10,
            "render": true,
            "attrName": "galleryLayout",
            "label": "Layout",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "grid": {
                    "label": "Six Images"
                  },
                  "one_large_four_small": {
                    "label": "One Large Image, Four Small"
                  }
                }
              }
            },
            "features": {
              "sticky": false,
              "responsive": true,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    },
    "startAtImage": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "1"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyGallery",
            "priority": 20,
            "render": true,
            "attrName": "startAtImage",
            "label": "Start at Image #",
            "component": {
              "name": "divi/text",
              "type": "field",
              "props": {
                "inputType": "number"
              }
            },
            "features": {
              "sticky": false,
              "responsive": true,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    },
    "outputRatio": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "4:3"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyGallery",
            "priority": 30,
            "render": true,
            "attrName": "outputRatio",
            "label": "Image Ratio",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "3:2": {
                    "label": "3:2"
                  },
                  "4:3": {
                    "label": "4:3"
                  },
                  "16:9": {
                    "label": "16:9"
                  },
                  "1:1": {
                    "label": "Square"
                  }
                }
              }
            },
            "features": {
              "sticky": false,
              "responsive": true,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "propertyGallery": {
        "panel": "content",
        "priority": 10,
        "groupName": "propertyGallery",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Property Gallery"
          }
        }
      }
    }
  },
  "wrapper": {
    "status": true,
    "tag": "div"
  }
}