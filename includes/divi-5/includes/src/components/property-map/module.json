{
  "name": "propertyhive/property-map",
  "title": "Property Map",
  "titles": "Property Map",
  "category": "module",
  "moduleClassName": "propertyhive_divi5_property_map",
  "moduleOrderClassName": "propertyhive_divi5_property_map",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "default": {
        "meta": {
          "adminLabel": {
            "desktop": {
              "value": "Property Map"
            }
          }
        }
      },
      "settings": {
        "meta": {
          "adminLabel": {}
        },
        "decoration": {
          "layout": {},
          "background": {},
          "sizing": {},
          "spacing": {},
          "border": {},
          "disabledOn": {},
          "position": {},
          "zIndex": {}
        }
      }
    },
    "height": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "400px"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyMap",
            "priority": 10,
            "render": true,
            "attrName": "height",
            "label": "Map Height",
            "component": {
              "name": "divi/range",
              "type": "field",
              "props": {
                "allowedUnits": [
                  "px",
                  "em",
                  "rem",
                  "vh",
                  "vw",
                  "%"
                ],
                "defaultUnit": "px",
                "min": 1,
                "max": 1200
              }
            },
            "description": "Controls the map height.",
            "features": {
              "sticky": false,
              "responsive": true,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    },
    "zoom": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "14"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyMap",
            "priority": 20,
            "render": true,
            "attrName": "zoom",
            "label": "Zoom",
            "component": {
              "name": "divi/text",
              "type": "field",
              "props": {
                "inputType": "number"
              }
            },
            "description": "Controls the map zoom level. Enter an integer, normally between 1 and 20.",
            "features": {
              "sticky": false,
              "responsive": true,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    },
    "scrollwheel": {
      "type": "object",
      "default": {
        "desktop": {
          "value": "true"
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "propertyMap",
            "priority": 30,
            "render": true,
            "attrName": "scrollwheel",
            "label": "Scrollwheel Zoom",
            "component": {
              "name": "divi/select",
              "type": "field",
              "props": {
                "options": {
                  "true": {
                    "label": "True"
                  },
                  "false": {
                    "label": "False"
                  }
                }
              }
            },
            "description": "Allows mouse wheel zooming on the map.",
            "features": {
              "sticky": false,
              "responsive": false,
              "hover": false,
              "dynamicContent": false
            }
          }
        }
      }
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "propertyMap": {
        "panel": "content",
        "priority": 10,
        "groupName": "propertyMap",
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Map Settings"
          }
        }
      }
    }
  },
  "wrapper": {
    "status": true,
    "tag": "div"
  }
}